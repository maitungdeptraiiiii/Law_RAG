OPENAI_API_KEY=your_openai_api_key_here

# Runtime mode.
# openai: use OpenAI API for chat and embeddings by default.
# local: use a local OpenAI-compatible chat server and local SentenceTransformers embeddings by default.
RAG_MODE=openai

# Chat/rewrite LLM provider.
# openai: use OpenAI API.
# local: use a local OpenAI-compatible server such as vLLM or LM Studio.
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENAI_MEMORY_MODEL=gpt-5.4-mini
OPENAI_QUERY_REWRITE_MODEL=gpt-5.4-mini
LOCAL_LLM_BASE_URL=http://localhost:8000/v1
LOCAL_LLM_API_KEY=local
LOCAL_CHAT_MODEL=qwen2.5:7b-instruct
LOCAL_MEMORY_MODEL=qwen2.5:7b-instruct
LOCAL_QUERY_REWRITE_MODEL=qwen2.5:7b-instruct

# Embedding provider for vector index build and vector query.
# openai: OpenAI embeddings.
# local-openai: local OpenAI-compatible /v1/embeddings endpoint.
# sentence-transformers: in-process HuggingFace SentenceTransformers model.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LOCAL_EMBEDDING_PROVIDER=sentence-transformers
LOCAL_EMBEDDING_MODEL=intfloat/multilingual-e5-base
LOCAL_EMBEDDING_BASE_URL=http://localhost:8001/v1
LOCAL_EMBEDDING_API_KEY=local
VECTOR_DIR=

# Optional overrides. Usually leave these blank and switch with RAG_MODE instead.
LLM_PROVIDER=
CHAT_MODEL=
MEMORY_MODEL=
QUERY_REWRITE_MODEL=
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=

# Optional: only needed when using MongoDB Atlas as vector backend.
MONGODB_ATLAS_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0
MONGODB_ATLAS_DB=law_rag
MONGODB_ATLAS_COLLECTION=legal_chunks
MONGODB_ATLAS_VECTOR_INDEX=legal_chunks_vector_index
